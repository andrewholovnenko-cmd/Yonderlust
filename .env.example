# --- Supabase (auth only for now) ---
# Project URL and anon/public key from your Supabase project settings.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Service data layer ---
# Which implementation the service layer uses:
#   mock = local typed fixtures (default, no backend needed)
#   live = Discover is routed through the `tura` engine (src/services/tura.ts);
#          everything else (manual planning, trip detail) stays on mock content
NEXT_PUBLIC_DATA_SOURCE=mock

# Base URL of this app, used for OAuth redirect callbacks.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- tura engine (used only when NEXT_PUBLIC_DATA_SOURCE=live) ---
# Vendored in-process at src/lib/tura — no separate server needed.
# Real flight prices via Travelpayouts (free, instant signup, no
# traffic/approval requirement — unlike Kiwi). Sign up at
# https://www.travelpayouts.com/ -> Tools -> Data API to get a token.
# See src/lib/tura/providers/travelpayoutsTransport.ts.
# Without it, the engine returns no flight results rather than fake ones.
TRAVELPAYOUTS_TOKEN=

# Hotel prices use Xotelo (data.xotelo.com) — no token needed at all, see
# src/lib/tura/providers/xoteloHotels.ts.
