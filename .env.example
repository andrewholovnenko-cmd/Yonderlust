# --- Supabase (auth only for now) ---
# Project URL and anon/public key from your Supabase project settings.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Service data layer ---
# Which implementation the service layer uses:
#   mock = local typed fixtures (default, no backend needed)
#   live = Discover is routed through the `tura` engine (src/services/tura.ts);
#          everything else (manual planning, trip detail) stays on mock content
NEXT_PUBLIC_DATA_SOURCE=mock

# Base URL of this app, used for OAuth redirect callbacks.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- tura engine (used only when NEXT_PUBLIC_DATA_SOURCE=live) ---
# Server-only — never sent to the browser. The Next.js route at
# /api/tura/search proxies to this so the browser doesn't need (or get) tura's
# address directly. Run tura's own `npm run dev` on this port separately.
TURA_API_BASE_URL=http://localhost:3001
